---
import PublicLayout from '../layouts/PublicLayout.astro'
import { getArticles, getCategories, getTags } from '../lib/api'
import type { ArticleListVO, CategoryVO, TagVO } from '../lib/types'

const pageNum = Number(Astro.url.searchParams.get('page') || 1)
const pageSize = 10

let articles: ArticleListVO[] = []
let total = 0
let categories: CategoryVO[] = []
let tags: TagVO[] = []
let error: string | null = null

try {
  const [artRes, catRes, tagRes] = await Promise.all([
    getArticles({ pageNum, pageSize, orderBy: 'create_time' }),
    getCategories(),
    getTags(),
  ])
  articles = artRes.data.records
  total = artRes.data.total
  categories = catRes.data
  tags = tagRes.data
} catch (e) {
  error = e instanceof Error ? e.message : '加载失败'
}

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
}
const totalPages = Math.ceil(total / pageSize)
---

<PublicLayout title="首页">
  <div class="max-w-3xl mx-auto px-5 py-16 animate-fade-in-up">
    <!-- Page header -->
    <h1 class="text-[34px] font-bold text-[rgb(var(--color-text))] mb-2">最新文章</h1>
    <p class="text-[15px] text-[rgb(var(--color-text-tertiary))] mb-12">共 {total} 篇文章</p>

    {error && <p class="text-center py-12 text-[rgb(var(--color-text-tertiary))]">{error}</p>}

    <!-- Post list -->
    <div class="space-y-12">
      {articles.length === 0 && !error && <p class="text-center py-12 text-[rgb(var(--color-text-tertiary))]">暂无文章</p>}
      {
        articles.map(a => (
          <article>
            <a href={`/articles/${a.id}`} class="group block">
              <h2 class="text-[21px] font-bold text-[rgb(var(--color-text))] group-hover:text-[rgb(var(--color-accent))] transition-colors leading-snug mb-1.5">
                {a.title}
              </h2>
              <div class="flex items-center gap-3 text-[14px] text-[rgb(var(--color-text-tertiary))] mb-3">
                <time>{formatDate(a.createTime)}</time>
                {a.categoryName && <span>&middot; {a.categoryName}</span>}
                <span>&middot; {a.viewCount} 次阅读</span>
              </div>
              <p class="text-[16px] text-[rgb(var(--color-text-secondary))] leading-relaxed line-clamp-3">
                {a.summary || '暂无摘要'}
              </p>
            </a>
            <div class="flex flex-wrap gap-1.5 mt-3">
              {a.tags.map(t => (
                <a href={`/tags/${t}`} class="tag">{t}</a>
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <!-- Pagination -->
    {
      totalPages > 1 && (
        <nav class="flex justify-center gap-2 mt-16 pt-8 border-t border-[rgb(var(--color-border))]">
          {
            Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
              <a
                href={`/?page=${p}`}
                class={`w-9 h-9 rounded-md text-[14px] font-medium flex items-center justify-center transition-colors ${
                  p === pageNum
                    ? 'bg-[rgb(var(--color-accent))] text-white'
                    : 'text-[rgb(var(--color-text-secondary))] hover:bg-[rgb(var(--color-bg-secondary))] hover:text-[rgb(var(--color-text))]'
                }`}
              >
                {p}
              </a>
            ))
          }
        </nav>
      )
    }

    <!-- Tags section -->
    <section class="mt-20 pt-10 border-t border-[rgb(var(--color-border))]">
      <h2 class="text-[17px] font-bold text-[rgb(var(--color-text))] mb-5">标签</h2>
      <div class="flex flex-wrap gap-2">
        {tags.map(t => <a href={`/tags/${t.id}`} class="tag">{t.name} <span class="text-[rgb(var(--color-text-tertiary))] ml-1">({t.articleCount})</span></a>)}
      </div>
    </section>

    <!-- Categories section -->
    <section class="mt-12">
      <h2 class="text-[17px] font-bold text-[rgb(var(--color-text))] mb-5">分类</h2>
      <div class="grid grid-cols-2 gap-2">
        {categories.map(c => (
          <a
            href={`/categories/${c.id}`}
            class="flex items-center justify-between py-2.5 px-3 rounded-md hover:bg-[rgb(var(--color-bg-secondary))] transition-colors text-[15px] text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text))]"
          >
            <span>{c.name}</span>
            <span class="text-[13px] text-[rgb(var(--color-text-tertiary))]">{c.articleCount}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</PublicLayout>
