---
import PublicLayout from '../../layouts/PublicLayout.astro'
import { getTags } from '../../lib/api'

export const prerender = false

let tags: { id: number; name: string; articleCount: number }[] = []

try {
  const res = await getTags()
  tags = res.data
} catch {}
---

<PublicLayout title="标签">
  <div class="max-w-3xl mx-auto px-5 py-16 animate-fade-in-up">
    <h1 class="text-[34px] font-bold text-[rgb(var(--color-text))] mb-2">标签</h1>
    <p class="text-[15px] text-[rgb(var(--color-text-tertiary))] mb-10">共 {tags.length} 个标签</p>

    {
      tags.length === 0
        ? <p class="text-center py-12 text-[rgb(var(--color-text-tertiary))]">暂无标签</p>
        : (
          <div class="flex flex-wrap gap-3">
            {tags.map(t => (
              <a href={`/tags/${t.id}`} class="tag">
                {t.name} ({t.articleCount})
              </a>
            ))}
          </div>
        )
    }
  </div>
</PublicLayout>
