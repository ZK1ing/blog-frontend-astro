---
import BaseLayout from './BaseLayout.astro'

const menuItems = [
  { label: '仪表盘', path: '/admin', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { label: '文章', path: '/admin/articles', icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z' },
  { label: '分类', path: '/admin/categories', icon: 'M2.25 7.125C2.25 6.504 2.754 6 3.375 6h18c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-3.375M2.25 7.125h18M2.25 7.125V4.875C2.25 4.254 2.754 3.75 3.375 3.75h18c.621 0 1.125.504 1.125 1.125v2.25M2.25 7.125v9.75c0 .621.504 1.125 1.125 1.125h18c.621 0 1.125-.504 1.125-1.125v-9.75' },
  { label: '标签', path: '/admin/tags', icon: 'M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z' },
  { label: '评论', path: '/admin/comments', icon: 'M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 01-.923 1.785A5.969 5.969 0 006 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337z' },
  { label: '文件', path: '/admin/files', icon: 'M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5' },
]

const currentPath = Astro.url.pathname
---

<BaseLayout title="管理后台">
  <div class="flex h-screen overflow-hidden bg-white">
    <!-- Sidebar -->
    <aside class="w-[220px] flex-shrink-0 border-r border-gray-100 flex flex-col bg-gray-50/50">
      <div class="px-5 py-5">
        <a href="/admin" class="text-[15px] font-semibold text-[#1d1d1f] tracking-tight">Blog Admin</a>
      </div>
      <nav class="flex-1 px-3 space-y-0.5">
        {
          menuItems.map(item => (
            <a
              href={item.path}
              class={`
                flex items-center gap-3 px-3 py-2 rounded-lg text-[14px] transition-colors
                ${currentPath === item.path || (item.path !== '/admin' && currentPath.startsWith(item.path))
                  ? 'bg-gray-200 text-[#1d1d1f] font-medium'
                  : 'text-[#6e6e73] hover:bg-gray-100 hover:text-[#1d1d1f]'}
              `}
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon}/>
              </svg>
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="px-5 py-4 border-t border-gray-100">
        <a href="/" class="text-[12px] text-[#aeaeb2] hover:text-[#6e6e73] transition-colors" target="_blank">
          前往前台 →
        </a>
      </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col min-w-0">
      <header class="h-14 border-b border-gray-100 flex items-center px-6 flex-shrink-0">
        <h1 class="text-[15px] font-medium text-[#1d1d1f]">管理后台</h1>
      </header>
      <main class="flex-1 overflow-y-auto bg-gray-50/50 p-6">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>
