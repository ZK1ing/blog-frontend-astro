<header class="sticky top-0 z-50 bg-[rgb(var(--color-bg))]/80 backdrop-blur-md border-b border-[rgb(var(--color-border))]">
  <div class="max-w-3xl mx-auto px-5 h-14 flex items-center justify-between">
    <a href="/" class="text-[18px] font-bold text-[rgb(var(--color-text))] tracking-tight">Blog</a>

    <div class="flex items-center gap-5">
      <a href="/" class="text-[15px] font-medium text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text))] transition-colors">首页</a>
      <a href="/tags" class="text-[15px] font-medium text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text))] transition-colors">标签</a>
      <a href="/search" class="text-[15px] font-medium text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text))] transition-colors">搜索</a>
      <a href="/login" class="text-[15px] font-medium text-[rgb(var(--color-text-tertiary))] hover:text-[rgb(var(--color-text))] transition-colors">登录</a>

      <!-- Theme toggle -->
      <button id="theme-toggle" class="p-1.5 rounded-md hover:bg-[rgb(var(--color-bg-secondary))] transition-colors" aria-label="切换主题">
        <svg class="sun w-[18px] h-[18px] text-[rgb(var(--color-text-secondary))]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
        </svg>
        <svg class="moon w-[18px] h-[18px] text-[rgb(var(--color-text-secondary))]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle')!
  const html = document.documentElement

  // Init from localStorage
  if (localStorage.getItem('theme') === 'dark') html.classList.add('dark')

  toggle.addEventListener('click', () => {
    html.classList.toggle('dark')
    localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light')
  })
</script>
