---
export interface Props {
  name: string
  href?: string
}
const { name, href } = Astro.props
const Tag = href ? 'a' : 'span'
---

<Tag
  {...(href ? { href } : {})}
  class="inline-flex items-center px-3 py-1 rounded-full text-[12px] font-medium bg-gray-100 text-[#6e6e73] border border-gray-200 hover:border-gray-300 hover:text-[#1d1d1f] transition-colors"
>
  #{name}
</Tag>
